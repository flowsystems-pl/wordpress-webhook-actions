#: admin/src/views/ExternalCronView.vue
msgid ""
"%1$s/wp-cron.php?doing_wp_cron%2$s — runs all WordPress scheduled tasks. "
"Min interval: 60s. %1$sDISABLE_WP_CRON%2$s is added to "
"%1$swp-config.php%2$s automatically."
msgstr ""
"%1$s/wp-cron.php?doing_wp_cron%2$s — uruchamia wszystkie zaplanowane "
"zadania WordPress. Min. interwał: 60 s. %1$sDISABLE_WP_CRON%2$s jest "
"automatycznie dodawane do %1$swp-config.php%2$s."

#: admin/src/views/ExternalCronView.vue
msgid ""
"%1$s/wp-json/fswa/v1/cron/process?token=…%2$s — processes only the webhook "
"queue. Min interval: 20s."
msgstr ""
"%1$s/wp-json/fswa/v1/cron/process?token=…%2$s — przetwarza tylko kolejkę "
"webhooków. Min. interwał: 20 s."

#: admin/src/components/PayloadGlueDrawer.vue
msgid ""
"%1$sAvailable variables:%2$s %3$s$payload%4$s (mapped array), %3$s$args%4$s "
"(%5$s$payload['args']%6$s)"
msgstr ""
"%1$sDostępne zmienne:%2$s %3$s$payload%4$s (zmapowana tablica), "
"%3$s$args%4$s (%5$s$payload['args']%6$s)"

#: admin/src/components/PayloadGlueDrawer.vue
msgid ""
"%1$sAvailable variables:%2$s %3$s$payload%4$s (sent), "
"%3$s$originalPayload%4$s (pre-mapping), %3$s$responseCode%4$s, "
"%3$s$responseBody%4$s"
msgstr ""
"%1$sDostępne zmienne:%2$s %3$s$payload%4$s (wysłany), "
"%3$s$originalPayload%4$s (przed mapowaniem), %3$s$responseCode%4$s, "
"%3$s$responseBody%4$s"

#: admin/src/views/ExternalCronView.vue
msgid "%1$sDISABLE_WP_CRON%2$s is active — WP-Cron auto-spawn is disabled."
msgstr ""
"%1$sDISABLE_WP_CRON%2$s jest aktywne — automatyczne uruchamianie WP-Cron "
"jest wyłączone."

#: admin/src/views/ExternalCronView.vue
msgid "%1$sDISABLE_WP_CRON%2$s will be written to %1$swp-config.php%2$s on save."
msgstr ""
"%1$sDISABLE_WP_CRON%2$s zostanie zapisane w %1$swp-config.php%2$s podczas "
"zapisywania."

#: admin/src/views/VaultView.vue
msgid ""
"%1$sFSWA_SECRET_KEY%2$s is defined and your credentials still work, but a "
"copy of the old key remains in the database — so you don't yet get the full "
"benefit. Re-encrypt now to seal every secret with the wp-config key and "
"delete the database key."
msgstr ""
"%1$sFSWA_SECRET_KEY%2$s jest zdefiniowany i Twoje poświadczenia nadal "
"działają, ale kopia starego klucza pozostaje w bazie danych — więc nie "
"korzystasz jeszcze z pełnej ochrony. Zaszyfruj ponownie, aby zabezpieczyć "
"każdy sekret kluczem z wp-config i usunąć klucz z bazy danych."

#: admin/src/views/VaultView.vue
msgid ""
"%1$sFormat:%2$s any long, random, secret string (64+ characters "
"recommended). Generate one from the %3$sWordPress salt generator%4$s or "
"with %5$swp_generate_password(64, true, true)%6$s."
msgstr ""
"%1$sFormat:%2$s dowolny długi, losowy, tajny ciąg (zalecane 64+ znaków). "
"Wygeneruj go za pomocą %3$sgeneratora soli WordPress%4$s lub funkcji "
"%5$swp_generate_password(64, true, true)%6$s."

#: admin/src/views/VaultView.vue
msgid ""
"%1$sKeep it stable &amp; backed up:%2$s don't change or lose this value "
"once credentials are sealed with it, or they become unrecoverable."
msgstr ""
"%1$sUtrzymuj go stabilnie i twórz kopie zapasowe:%2$s nie zmieniaj ani nie "
"trać tej wartości po zabezpieczeniu nią poświadczeń, w przeciwnym razie "
"staną się nieodzyskiwalne."

#: admin/src/views/ProView.vue
msgid "%1$sPriority support%2$s — Pro subscribers get a direct response via email."
msgstr ""
"%1$sPriorytetowe wsparcie%2$s — subskrybenci Pro otrzymują bezpośrednią "
"odpowiedź e-mailem."

#: admin/src/views/VaultView.vue
msgid ""
"%1$sSafe to add anytime:%2$s existing credentials keep working immediately. "
"After adding it, return here and click the %3$sRe-encrypt%4$s button that "
"appears to finish the move and remove the database key."
msgstr ""
"%1$sMożna dodać w każdej chwili:%2$s istniejące poświadczenia od razu "
"działają. Po dodaniu wróć tutaj i kliknij przycisk %3$sZaszyfruj "
"ponownie%4$s, który się pojawi, aby dokończyć przeniesienie i usunąć klucz "
"z bazy danych."

#: admin/src/components/PayloadGlueDrawer.vue
msgid ""
"%1$sShorthand:%2$s works for any variable, e.g. %3$s{{ $args.0.field }}%4$s "
"→ %3$s$args[0]['field']%4$s, %3$s{{ $payload.key }}%4$s → "
"%3$s$payload['key']%4$s"
msgstr ""
"%1$sSkrót:%2$s działa dla dowolnej zmiennej, np. %3$s{{ $args.0.field "
"}}%4$s → %3$s$args[0]['field']%4$s, %3$s{{ $payload.key }}%4$s → "
"%3$s$payload['key']%4$s"

#: admin/src/components/PayloadGlueDrawer.vue
msgid ""
"%1$sShorthand:%2$s works for any variable, e.g. %3$s{{ "
"$originalPayload.args.0.id }}%4$s → "
"%3$s$originalPayload['args'][0]['id']%4$s"
msgstr ""
"%1$sSkrót:%2$s działa dla dowolnej zmiennej, np. %3$s{{ "
"$originalPayload.args.0.id }}%4$s → "
"%3$s$originalPayload['args'][0]['id']%4$s"

#: admin/src/views/ExternalCronView.vue
msgid ""
"%1$swp-config.php%2$s is not writable. Add this line manually before the "
"“That’s all” comment: %3$sdefine( 'DISABLE_WP_CRON', true );%4$s"
msgstr ""
"Plik %1$swp-config.php%2$s nie jest zapisywalny. Dodaj tę linię ręcznie "
"przed komentarzem „That’s all”: %3$sdefine( 'DISABLE_WP_CRON', true );%4$s"

